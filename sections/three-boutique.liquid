{% endstylesheet %}

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@{{ three_version }}/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@{{ three_version }}/examples/jsm/"
  }
}
</script>
<script async src="https://ga.jspm.io/npm:es-module-shims@1.10.0/dist/es-module-shims.js" crossorigin="anonymous"></script>

<script type="module">
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { DRACOLoader } from 'three/addons/loaders/DRACOLoader.js';
  import { KTX2Loader } from 'three/addons/loaders/KTX2Loader.js';
  import { MeshoptDecoder } from 'three/addons/libs/meshopt_decoder.module.js';
  import { PointerLockControls } from 'three/addons/controls/PointerLockControls.js';
  import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

  const root = document.querySelector('[data-boutique]');
  if (root) {
    bootBoutique(root).catch((error) => {
      console.error('[boutique] fatal init error', error);
      showFallback(root);
    });
  }

  async function bootBoutique(root) {
    const productsScript = root.querySelector('[data-boutique-products]');
    const configScript = root.querySelector('[data-boutique-config]');
    const products = JSON.parse(productsScript ? productsScript.textContent : '[]');
    const config = JSON.parse(configScript ? configScript.textContent : '{}');

    root.style.setProperty('--boutique-bg', config.wallColor || '#0b0b0f');
    root.style.setProperty('--boutique-accent', config.accentColor || '#f5f5f5');

    const intro = root.querySelector('[data-boutique-intro]');
    const enterBtn = root.querySelector('[data-boutique-enter]');
    const skipBtn = root.querySelector('[data-boutique-skip-3d]');
    const loading = root.querySelector('[data-boutique-loading]');
    const loadingBar = root.querySelector('[data-boutique-loading-bar]');
    const loadingText = root.querySelector('[data-boutique-loading-text]');
    const stage = root.querySelector('[data-boutique-stage]');
    const hud = root.querySelector('[data-boutique-hud]');
    const fallback = root.querySelector('[data-boutique-fallback]');
    const crosshairRing = root.querySelector('[data-boutique-crosshair-ring]');
    const crosshairHint = root.querySelector('[data-boutique-crosshair-hint]');
    const crosshairText = root.querySelector('[data-boutique-crosshair-text]');
    const joystick = root.querySelector('[data-boutique-joystick]');
    const joystickStick = root.querySelector('[data-boutique-joystick-stick]');

    initCart(root);

    if (products.length === 0) {
      showIntroOnly(root, intro, loading);
      if (skipBtn) skipBtn.focus();
      return;
    }

    setupProductDialog(root, products, config);

    intro.hidden = false;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouch = matchMedia('(pointer: coarse)').matches || 'ontouchstart' in window;

    if (!supportsWebGL()) {
      showFallback(root);
      hideLoading(loading);
      return;
    }

    let started = false;
    const start = (use3d) => {
      if (started) return;
      started = true;
      if (use3d) {
        runScene(root, products, config, {
          intro,
          loading,
          loadingBar,
          loadingText,
          stage,
          hud,
          crosshairRing,
          crosshairHint,
          crosshairText,
          joystick,
          joystickStick,
          isTouch,
        }).catch((error) => {
          console.error('[boutique] scene error', error);
          showFallback(root);
        });
      } else {
        intro.hidden = true;
        hideLoading(loading);
        showFallback(root);
      }
    };

    if (enterBtn) enterBtn.addEventListener('click', () => start(true));
    if (skipBtn) skipBtn.addEventListener('click', () => start(false));

    if (reduceMotion) {
      if (skipBtn) skipBtn.focus();
    } else if (enterBtn && !enterBtn.disabled) {
      enterBtn.focus();
    }
  }

  function supportsWebGL() {
    try {
      const canvas = document.createElement('canvas');
      return Boolean(window.WebGLRenderingContext && (canvas.getContext('webgl2') || canvas.getContext('webgl')));
    } catch (_e) {
      return false;
    }
  }

  function showFallback(root) {
    const fallback = root.querySelector('[data-boutique-fallback]');
    if (fallback) {
      fallback.hidden = false;
    }
    const intro = root.querySelector('[data-boutique-intro]');
    if (intro) intro.hidden = true;
    const loading = root.querySelector('[data-boutique-loading]');
    if (loading) loading.hidden = true;
  }

  function showIntroOnly(root, intro, loading) {
    intro.hidden = false;
    if (loading) loading.hidden = true;
  }

  function hideLoading(loading) {
    if (loading) loading.hidden = true;
  }

  async function runScene(root, products, config, els) {
    const stage = els.stage;
    let dprCap = 2;
    if (config.quality === 'low') dprCap = 1;
    else if (config.quality === 'medium') dprCap = 1.5;
    const dpr = Math.min(window.devicePixelRatio || 1, dprCap);
    const enableShadows = !!config.enableShadows;

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false, powerPreference: 'high-performance' });
    renderer.setPixelRatio(dpr);
    renderer.setClearColor(new THREE.Color(config.wallColor || '#0b0b0f'));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.0;
    if (enableShadows) {
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    }
    stage.appendChild(renderer.domElement);

    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog(new THREE.Color(config.wallColor || '#0b0b0f'), 8, 24);

    const camera = new THREE.PerspectiveCamera(70, 1, 0.05, 200);
    camera.position.set(0, 1.65, 0);

    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

    buildRoom(scene, config);
    addLights(scene, config, enableShadows);

    const dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath('https://cdn.jsdelivr.net/npm/three@' + (config.threeVersion || '0.165.0') + '/examples/jsm/libs/draco/gltf/');
    dracoLoader.setDecoderConfig({ type: 'js' });

    const ktx2Loader = new KTX2Loader()
      .setTranscoderPath('https://cdn.jsdelivr.net/npm/three@' + (config.threeVersion || '0.165.0') + '/examples/jsm/libs/basis/')
      .detectSupport(renderer);

    const gltfLoader = new GLTFLoader();
    gltfLoader.setDRACOLoader(dracoLoader);
    gltfLoader.setKTX2Loader(ktx2Loader);
    gltfLoader.setMeshoptDecoder(MeshoptDecoder);

    const interactives = [];
    const pedestals = [];
    const spinningGroups = [];

    const radius = Math.max(4, Math.min(15, Number(config.roomRadius) || 9));
    const ringRadius = radius - 2.2;
    const count = products.length;

    for (let i = 0; i < count; i++) {
      const p = products[i];
      const angle = (i / count) * Math.PI * 2;
      const x = Math.sin(angle) * ringRadius;
      const z = -Math.cos(angle) * ringRadius;
      const pedestal = buildPedestal(scene, x, z, angle, config);
      pedestals.push(pedestal);
      const display = buildPlaceholderDisplay(scene, p, x, z, angle, config);
      pedestal.userData.product = p;
      interactives.push(pedestal, display.pickHelper);
      hydrateDisplay(p, config, gltfLoader, display, spinningGroups);
    }

    addFloorMarkings(scene, ringRadius, config);

    const controls = new PointerLockControls(camera, renderer.domElement);
    scene.add(controls.getObject());

    const onUnlockPointer = () => {
      try {
        controls.unlock();
      } catch (_e) {
        /* ignore */
      }
    };
    document.addEventListener('boutique-unlock-pointer', onUnlockPointer);

    const movement = { forward: 0, strafe: 0, sprint: false };
    const direction = new THREE.Vector3();

    const keyMap = {
      KeyW: 'forward+', ArrowUp: 'forward+',
      KeyS: 'forward-', ArrowDown: 'forward-',
      KeyA: 'strafe-', ArrowLeft: 'strafe-',
      KeyD: 'strafe+', ArrowRight: 'strafe+',
    };

    const pressed = new Set();
    const updateMovement = () => {
      let f = 0, s = 0;
      pressed.forEach((code) => {
        const m = keyMap[code];
        if (!m) return;
        if (m === 'forward+') f = 1;
        else if (m === 'forward-') f = -1;
        else if (m === 'strafe+') s = 1;
        else if (m === 'strafe-') s = -1;
      });
      movement.forward = f;
      movement.strafe = s;
    };

    const isProductDialogOpen = () => {
      const d = root.querySelector('[data-boutique-product]');
      const c = root.querySelector('[data-boutique-cart]');
      return (d && !d.hidden) || (c && !c.hidden);
    };

    const onKeyDown = (e) => {
      if (isProductDialogOpen()) return;
      if (e.code === 'Escape') {
        controls.unlock();
        return;
      }
      if (e.code === 'KeyE') {
        e.preventDefault();
        attemptInteract();
      }
      if (keyMap[e.code]) {
        pressed.add(e.code);
        updateMovement();
      }
      if (e.code === 'ShiftLeft' || e.code === 'ShiftRight') movement.sprint = true;
    };
    const onKeyUp = (e) => {
      if (keyMap[e.code]) {
        pressed.delete(e.code);
        updateMovement();
      }
      if (e.code === 'ShiftLeft' || e.code === 'ShiftRight') movement.sprint = false;
    };
    document.addEventListener('keydown', onKeyDown);
    document.addEventListener('keyup', onKeyUp);

    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2(0, 0);

    const setHint = (text) => {
      if (!els.crosshairHint || !els.crosshairText) return;
      if (!text) {
        els.crosshairHint.hidden = true;
      } else {
        els.crosshairText.textContent = text;
        els.crosshairHint.hidden = false;
      }
    };

    let hovered = null;
    const updateHover = () => {
      raycaster.setFromCamera(pointer, camera);
      const hits = raycaster.intersectObjects(interactives, true);
      let target = null;
      for (const h of hits) {
        const obj = findInteractive(h.object);
        if (obj) { target = obj; break; }
      }
      if (target !== hovered) {
        hovered = target;
        if (els.crosshairRing) els.crosshairRing.classList.toggle('is-active', !!hovered);
        if (hovered) {
          const productHandle = (hovered.userData && hovered.userData.product) ? hovered.userData.product.title : '';
          setHint(productHandle);
        } else {
          setHint('');
        }
      }
    };

    const attemptInteract = () => {
      if (!hovered) return;
      const product = hovered.userData.product;
      if (product) {
        if (controls.isLocked) controls.unlock();
        openProduct(product);
      }
    };

    const updatePointerFromEvent = (e) => {
      const rect = renderer.domElement.getBoundingClientRect();
      pointer.x = ((e.clientX - rect.left) / Math.max(1, rect.width)) * 2 - 1;
      pointer.y = -((e.clientY - rect.top) / Math.max(1, rect.height)) * 2 + 1;
    };

    renderer.domElement.addEventListener('mousemove', (e) => {
      if (!controls.isLocked) updatePointerFromEvent(e);
    });

    renderer.domElement.addEventListener('click', (e) => {
      if (els.isTouch) return;
      if (!controls.isLocked) updatePointerFromEvent(e);
      updateHover();
      if (hovered) {
        e.preventDefault();
        attemptInteract();
        return;
      }
      try {
        controls.lock();
      } catch (_err) {
        /* iframe / unsupported — just keep aim-and-click mode */
      }
    });

    controls.addEventListener('lock', () => {
      stage.classList.add('is-locked');
      pointer.set(0, 0);
    });
    controls.addEventListener('unlock', () => {
      stage.classList.remove('is-locked');
    });

    if (els.isTouch) {
      setupTouchControls({
        canvas: renderer.domElement,
        joystick: els.joystick,
        stick: els.joystickStick,
        movement,
        camera,
        controlsObject: controls.getObject(),
        onTap: () => attemptInteract(),
        onTapPoint: (x, y) => {
          const rect = renderer.domElement.getBoundingClientRect();
          pointer.x = ((x - rect.left) / Math.max(1, rect.width)) * 2 - 1;
          pointer.y = -((y - rect.top) / Math.max(1, rect.height)) * 2 + 1;
          updateHover();
        },
      });
    }

    const clock = new THREE.Clock();
    const room = { half: radius - 0.6 };

    const playerSpeed = 3.4;
    const playerSprint = 5.5;

    const tick = () => {
      const delta = Math.min(clock.getDelta(), 0.05);

      if (isProductDialogOpen()) {
        movement.forward = 0;
        movement.strafe = 0;
        movement.sprint = false;
      }

      if (controls.isLocked || movement.forward !== 0 || movement.strafe !== 0) {
        const speed = (movement.sprint ? playerSprint : playerSpeed) * delta;
        direction.set(movement.strafe, 0, -movement.forward);
        if (direction.lengthSq() > 1e-6) direction.normalize();
        const obj = controls.getObject();
        const forward = new THREE.Vector3();
        camera.getWorldDirection(forward); forward.y = 0; forward.normalize();
        const right = new THREE.Vector3().crossVectors(forward, new THREE.Vector3(0, 1, 0)).normalize();
        const move = new THREE.Vector3();
        move.addScaledVector(forward, -direction.z).addScaledVector(right, direction.x);
        obj.position.addScaledVector(move, speed);

        const half = room.half;
        obj.position.x = Math.max(-half, Math.min(half, obj.position.x));
        obj.position.z = Math.max(-half, Math.min(half, obj.position.z));
        obj.position.y = 1.65;
      }

      for (let i = 0; i < spinningGroups.length; i++) {
        spinningGroups[i].rotation.y += delta * 0.45;
      }

      updateHover();
      renderer.render(scene, camera);
      requestAnimationFrame(tick);
    };

    requestSize(renderer, camera, stage);
    window.addEventListener('resize', () => requestSize(renderer, camera, stage));

    finishLoading(els.loading);
    els.intro.hidden = true;
    if (els.hud) els.hud.hidden = false;
    if (els.isTouch && els.joystick) els.joystick.hidden = false;

    const back = root.querySelector('[data-boutique-back]');
    if (back) back.addEventListener('click', () => {
      controls.unlock();
      els.hud.hidden = true;
      els.intro.hidden = false;
    });

    requestAnimationFrame(tick);
  }

  function findInteractive(obj) {
    let cur = obj;
    while (cur) {
      if (cur.userData && cur.userData.product) return cur;
      cur = cur.parent;
    }
    return null;
  }

  function buildRoom(scene, config) {
    const radius = Math.max(4, Math.min(15, Number(config.roomRadius) || 9));
    const wallHeight = 4.5;

    const floorGeo = new THREE.CircleGeometry(radius + 0.5, 64);
    const floorMat = new THREE.MeshStandardMaterial({
      color: new THREE.Color(config.floorColor || '#1a1a22'),
      roughness: 0.45,
      metalness: 0.1,
    });
    if (config.floorTexture) {
      new THREE.TextureLoader().setCrossOrigin('anonymous').load(config.floorTexture, (tex) => {
        tex.colorSpace = THREE.SRGBColorSpace;
        tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
        tex.repeat.set(6, 6);
        floorMat.map = tex;
        floorMat.needsUpdate = true;
      });
    }
    const floor = new THREE.Mesh(floorGeo, floorMat);
    floor.rotation.x = -Math.PI / 2;
    floor.receiveShadow = true;
    scene.add(floor);

    const ceiling = new THREE.Mesh(
      new THREE.CircleGeometry(radius + 0.5, 64),
      new THREE.MeshStandardMaterial({
        color: new THREE.Color(config.ceilingColor || '#0b0b0f'),
        roughness: 0.95,
        metalness: 0.0,
        side: THREE.DoubleSide,
      })
    );
    ceiling.rotation.x = Math.PI / 2;
    ceiling.position.y = wallHeight;
    scene.add(ceiling);

    const wallMat = new THREE.MeshStandardMaterial({
      color: new THREE.Color(config.wallColor || '#0e0e14'),
      roughness: 0.85,
      metalness: 0.05,
      side: THREE.BackSide,
    });
    if (config.wallTexture) {
      new THREE.TextureLoader().setCrossOrigin('anonymous').load(config.wallTexture, (tex) => {
        tex.colorSpace = THREE.SRGBColorSpace;
        tex.wrapS = tex.wrapT = THREE.RepeatWrapping;
        tex.repeat.set(6, 1);
        wallMat.map = tex;
        wallMat.needsUpdate = true;
      });
    }
    const wall = new THREE.Mesh(
      new THREE.CylinderGeometry(radius, radius, wallHeight, 64, 1, true),
      wallMat
    );
    wall.position.y = wallHeight / 2;
    scene.add(wall);

    if (config.skyboxImage) {
      new THREE.TextureLoader().setCrossOrigin('anonymous').load(config.skyboxImage, (tex) => {
        tex.colorSpace = THREE.SRGBColorSpace;
        tex.mapping = THREE.EquirectangularReflectionMapping;
        scene.background = tex;
        scene.environment = tex;
      });
    }
  }

  function addLights(scene, config, enableShadows) {
    const ambient = new THREE.HemisphereLight(0xffffff, 0x202028, 0.55);
    scene.add(ambient);

    const ceilingFill = new THREE.PointLight(0xffffff, 1.0, 18, 1.5);
    ceilingFill.position.set(0, 4.0, 0);
    scene.add(ceilingFill);

    const key = new THREE.DirectionalLight(0xffe7c8, 0.55);
    key.position.set(4, 6, 4);
    if (enableShadows) {
      key.castShadow = true;
      key.shadow.mapSize.set(1024, 1024);
      key.shadow.camera.near = 0.5;
      key.shadow.camera.far = 30;
      key.shadow.bias = -0.0002;
    }
    scene.add(key);

    const accentColor = new THREE.Color(config.accentColor || '#f5f5f5');
    const acc1 = new THREE.PointLight(accentColor, 0.4, 12, 2);
    acc1.position.set(-5, 2.5, -5);
    scene.add(acc1);
    const acc2 = new THREE.PointLight(accentColor, 0.3, 12, 2);
    acc2.position.set(5, 2.5, 5);
    scene.add(acc2);
  }

  function buildPedestal(scene, x, z, _angle, config) {
    const height = Math.max(0.4, Math.min(1.6, Number(config.pedestalHeight) || 1.0));
    const geo = new THREE.CylinderGeometry(0.55, 0.6, height, 32);
    const mat = new THREE.MeshStandardMaterial({
      color: new THREE.Color(config.accentColor || '#f5f5f5').multiplyScalar(0.18).add(new THREE.Color(0x111114)),
      roughness: 0.4,
      metalness: 0.25,
    });
    const mesh = new THREE.Mesh(geo, mat);
    mesh.position.set(x, height / 2, z);
    mesh.receiveShadow = true;
    if (mesh.material) mesh.material.envMapIntensity = 0.6;
    const halo = new THREE.Mesh(
      new THREE.RingGeometry(0.6, 0.7, 48),
      new THREE.MeshBasicMaterial({ color: new THREE.Color(config.accentColor || '#f5f5f5'), transparent: true, opacity: 0.18 })
    );
    halo.rotation.x = -Math.PI / 2;
    halo.position.set(x, 0.005, z);
    scene.add(halo);
    scene.add(mesh);
    mesh.userData.pedestalHeight = height;
    return mesh;
  }

  function buildPlaceholderDisplay(scene, product, x, z, angle, config) {
    const group = new THREE.Group();
    group.position.set(x, 0, z);
    group.rotation.y = angle;

    const placeholder = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.35, 0),
      new THREE.MeshStandardMaterial({
        color: new THREE.Color(config.accentColor || '#f5f5f5').multiplyScalar(0.5),
        roughness: 0.3,
        metalness: 0.5,
        wireframe: false,
      })
    );
    placeholder.position.y = 1.35;
    group.add(placeholder);

    const label = makeLabelSprite(product.title || '', config);
    label.position.set(0, 2.2, 0);
    group.add(label);

    const pickHelper = new THREE.Mesh(
      new THREE.BoxGeometry(1.4, 1.6, 1.4),
      new THREE.MeshBasicMaterial({ visible: false })
    );
    pickHelper.position.set(0, 1.4, 0);
    group.add(pickHelper);
    pickHelper.userData.product = product;

    scene.add(group);
    return { group, placeholder, label, pickHelper };
  }

  function hydrateDisplay(product, config, gltfLoader, display, spinningGroups) {
    const modelMedia = (product.media || []).find((m) => m.media_type === 'model' && m.sources && m.sources.length > 0);
    if (modelMedia) {
      const src = pickGlb(modelMedia.sources);
      if (src) {
        gltfLoader.load(
          src.url,
          (gltf) => {
            replacePlaceholderWithModel(display, gltf.scene, config, spinningGroups);
          },
          undefined,
          (err) => {
            console.warn('[boutique] failed to load model for', product.handle, err);
            replacePlaceholderWithImage(display, product, config, spinningGroups);
          }
        );
        return;
      }
    }
    replacePlaceholderWithImage(display, product, config, spinningGroups);
  }

  function pickGlb(sources) {
    return sources.find((s) => /glb/i.test(s.format || s.mime_type || s.url || '')) || sources[0];
  }

  function replacePlaceholderWithModel(display, modelScene, config, spinningGroups) {
    const group = display.group;
    if (display.placeholder) {
      group.remove(display.placeholder);
      disposeDeep(display.placeholder);
      display.placeholder = null;
    }

    const box = new THREE.Box3().setFromObject(modelScene);
    const size = new THREE.Vector3();
    const center = new THREE.Vector3();
    box.getSize(size);
    box.getCenter(center);

    const maxDim = Math.max(size.x, size.y, size.z) || 1;
    const targetSize = 0.9;
    const scale = targetSize / maxDim;
    modelScene.scale.setScalar(scale);

    modelScene.position.sub(center.clone().multiplyScalar(scale));
    modelScene.position.y = 1.05 + (size.y * scale) / 2;

    modelScene.traverse((child) => {
      if (child.isMesh) {
        child.castShadow = !!config.enableShadows;
        child.receiveShadow = false;
        if (child.material) {
          child.material.envMapIntensity = 1.0;
        }
      }
    });

    const spinPivot = new THREE.Group();
    spinPivot.add(modelScene);
    spinPivot.position.y = 0;
    group.add(spinPivot);
    spinningGroups.push(spinPivot);
  }

  function replacePlaceholderWithImage(display, product, config, spinningGroups) {
    const url = product.featured_image || (product.images && product.images[0]) || (product.media && product.media[0] && product.media[0].preview_url);
    const group = display.group;
    if (display.placeholder) {
      group.remove(display.placeholder);
      disposeDeep(display.placeholder);
      display.placeholder = null;
    }
    if (!url) return;

    new THREE.TextureLoader().setCrossOrigin('anonymous').load(
      url,
      (tex) => {
        tex.colorSpace = THREE.SRGBColorSpace;
        const aspect = (tex.image && tex.image.width && tex.image.height) ? tex.image.width / tex.image.height : 1;
        const height = 1.1;
        const width = height * aspect;
        const card = new THREE.Mesh(
          new THREE.PlaneGeometry(width, height),
          new THREE.MeshStandardMaterial({ map: tex, roughness: 0.4, metalness: 0.0, side: THREE.DoubleSide })
        );
        card.position.y = 1.05 + height / 2;
        const frameThickness = 0.04;
        const frame = new THREE.Mesh(
          new THREE.BoxGeometry(width + frameThickness * 2, height + frameThickness * 2, frameThickness * 0.5),
          new THREE.MeshStandardMaterial({
            color: new THREE.Color(config.accentColor || '#f5f5f5').multiplyScalar(0.3),
            roughness: 0.5,
            metalness: 0.6,
          })
        );
        frame.position.copy(card.position);
        frame.position.z -= 0.02;
        const wrap = new THREE.Group();
        wrap.add(frame);
        wrap.add(card);
        const spin = new THREE.Group();
        spin.add(wrap);
        group.add(spin);
        spinningGroups.push(spin);
      },
      undefined,
      (err) => {
        console.warn('[boutique] failed to load image for', product.handle, err);
      }
    );
  }

  function makeLabelSprite(text, config) {
    const canvas = document.createElement('canvas');
    const padding = 24;
    const fontSize = 32;
    canvas.width = 1024;
    canvas.height = 128;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = 'rgba(0,0,0,0.55)';
    roundRect(ctx, padding, 16, canvas.width - padding * 2, canvas.height - 32, 24);
    ctx.fill();
    ctx.fillStyle = config.accentColor || '#f5f5f5';
    ctx.font = '600 ' + fontSize + 'px system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    const maxWidth = canvas.width - padding * 4;
    const truncated = truncateText(ctx, text, maxWidth);
    ctx.fillText(truncated, canvas.width / 2, canvas.height / 2);
    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    texture.needsUpdate = true;
    const material = new THREE.SpriteMaterial({ map: texture, transparent: true, depthWrite: false });
    const sprite = new THREE.Sprite(material);
    sprite.scale.set(2.4, 0.3, 1);
    return sprite;
  }

  function truncateText(ctx, text, maxWidth) {
    const t = String(text || '');
    if (ctx.measureText(t).width <= maxWidth) return t;
    let lo = 0, hi = t.length;
    while (lo < hi) {
      const mid = Math.floor((lo + hi) / 2);
      const candidate = t.slice(0, mid) + '\u2026';
      if (ctx.measureText(candidate).width <= maxWidth) lo = mid + 1;
      else hi = mid;
    }
    return t.slice(0, Math.max(0, lo - 1)) + '\u2026';
  }

  function roundRect(ctx, x, y, w, h, r) {
    ctx.beginPath();
    ctx.moveTo(x + r, y);
    ctx.lineTo(x + w - r, y);
    ctx.quadraticCurveTo(x + w, y, x + w, y + r);
    ctx.lineTo(x + w, y + h - r);
    ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    ctx.lineTo(x + r, y + h);
    ctx.quadraticCurveTo(x, y + h, x, y + h - r);
    ctx.lineTo(x, y + r);
    ctx.quadraticCurveTo(x, y, x + r, y);
    ctx.closePath();
  }

  function addFloorMarkings(scene, ringRadius, config) {
    const ring = new THREE.Mesh(
      new THREE.RingGeometry(ringRadius - 0.05, ringRadius + 0.05, 96),
      new THREE.MeshBasicMaterial({
        color: new THREE.Color(config.accentColor || '#f5f5f5'),
        transparent: true,
        opacity: 0.08,
      })
    );
    ring.rotation.x = -Math.PI / 2;
    ring.position.y = 0.002;
    scene.add(ring);
  }

  function disposeDeep(obj) {
    obj.traverse((c) => {
      if (c.isMesh) {
        if (c.geometry) c.geometry.dispose();
        if (c.material) {
          if (Array.isArray(c.material)) c.material.forEach((m) => m.dispose());
          else c.material.dispose();
        }
      }
    });
  }

  function finishLoading(loading) {
    if (!loading) return;
    const bar = loading.querySelector('[data-boutique-loading-bar]');
    if (bar) bar.style.width = '100%';
    setTimeout(() => { loading.hidden = true; }, 200);
  }

  function requestSize(renderer, camera, stage) {
    const rect = stage.getBoundingClientRect();
    const w = Math.max(1, rect.width);
    const h = Math.max(1, rect.height);
    renderer.setSize(w, h, false);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  }

  function setupTouchControls(opts) {
    const { canvas, joystick, stick, movement, camera, controlsObject, onTap, onTapPoint } = opts;
    if (!joystick || !stick) return;

    let stickActive = false;
    let stickPointerId = null;
    let stickCenter = { x: 0, y: 0 };
    const baseRect = () => joystick.getBoundingClientRect();

    const endStick = () => {
      stickActive = false;
      stickPointerId = null;
      stick.style.transform = 'translate(-50%, -50%)';
      movement.forward = 0;
      movement.strafe = 0;
    };

    const handleStick = (e) => {
      const dx = e.clientX - stickCenter.x;
      const dy = e.clientY - stickCenter.y;
      const max = baseRect().width / 2 - 22;
      const len = Math.min(Math.sqrt(dx * dx + dy * dy), max);
      const ang = Math.atan2(dy, dx);
      const tx = Math.cos(ang) * len;
      const ty = Math.sin(ang) * len;
      stick.style.transform = 'translate(calc(-50% + ' + tx + 'px), calc(-50% + ' + ty + 'px))';
      const fx = (max > 0 ? tx / max : 0);
      const fy = (max > 0 ? ty / max : 0);
      const dead = 0.18;
      movement.strafe = Math.abs(fx) < dead ? 0 : fx;
      movement.forward = Math.abs(fy) < dead ? 0 : -fy;
    };

    joystick.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      stickActive = true;
      stickPointerId = e.pointerId;
      const r = baseRect();
      stickCenter = { x: r.left + r.width / 2, y: r.top + r.height / 2 };
      try { joystick.setPointerCapture(e.pointerId); } catch (_err) {}
      handleStick(e);
    });
    joystick.addEventListener('pointermove', (e) => {
      if (!stickActive || e.pointerId !== stickPointerId) return;
      handleStick(e);
    });
    joystick.addEventListener('pointerup', endStick);
    joystick.addEventListener('pointercancel', endStick);

    let lookActive = false;
    let lastX = 0, lastY = 0;
    let lookId = null;
    let lookStartX = 0, lookStartY = 0;
    let didMove = false;
    canvas.addEventListener('pointerdown', (e) => {
      if (e.pointerType === 'mouse') return;
      const r = joystick.getBoundingClientRect();
      if (e.clientX >= r.left && e.clientX <= r.right && e.clientY >= r.top && e.clientY <= r.bottom) return;
      lookActive = true;
      lookId = e.pointerId;
      lastX = lookStartX = e.clientX;
      lastY = lookStartY = e.clientY;
      didMove = false;
      try { canvas.setPointerCapture(e.pointerId); } catch (_err) {}
    });
    canvas.addEventListener('pointermove', (e) => {
      if (!lookActive || e.pointerId !== lookId) return;
      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;
      lastX = e.clientX;
      lastY = e.clientY;
      if (Math.abs(e.clientX - lookStartX) + Math.abs(e.clientY - lookStartY) > 6) didMove = true;
      controlsObject.rotation.y -= dx * 0.0028;
      const euler = new THREE.Euler(0, 0, 0, 'YXZ');
      euler.setFromQuaternion(camera.quaternion);
      euler.x = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, euler.x - dy * 0.0028));
      euler.y = 0;
      euler.z = 0;
      camera.quaternion.setFromEuler(euler);
    });
    canvas.addEventListener('pointerup', (e) => {
      if (!lookActive || e.pointerId !== lookId) return;
      lookActive = false;
      lookId = null;
      if (!didMove) {
        if (typeof onTapPoint === 'function') onTapPoint(e.clientX, e.clientY);
        if (typeof onTap === 'function') onTap();
      }
    });
    canvas.addEventListener('pointercancel', () => { lookActive = false; lookId = null; });
  }

  function setupProductDialog(root, products, config) {
    const dialog = root.querySelector('[data-boutique-product]');
    const closeEls = root.querySelectorAll('[data-boutique-product-close]');
    const titleEl = root.querySelector('[data-boutique-product-title]');
    const vendorEl = root.querySelector('[data-boutique-product-vendor]');
    const priceEl = root.querySelector('[data-boutique-product-price]');
    const compareEl = root.querySelector('[data-boutique-product-compare]');
    const stockEl = root.querySelector('[data-boutique-product-stock]');
    const optionsEl = root.querySelector('[data-boutique-product-options]');
    const descEl = root.querySelector('[data-boutique-product-description]');
    const linkEl = root.querySelector('[data-boutique-product-link]');
    const mediaEl = root.querySelector('[data-boutique-product-media]');
    const thumbsEl = root.querySelector('[data-boutique-product-thumbs]');
    const qtyInput = root.querySelector('[data-boutique-qty]');
    const qtyDecr = root.querySelector('[data-boutique-qty-decr]');
    const qtyIncr = root.querySelector('[data-boutique-qty-incr]');
    const addBtn = root.querySelector('[data-boutique-add]');
    const addLabel = root.querySelector('[data-boutique-add-label]');
    const addSpin = root.querySelector('[data-boutique-add-spin]');
    const addError = root.querySelector('[data-boutique-add-error]');

    let state = { product: null, variant: null, selectedOptions: [] };

    const close = () => {
      dialog.hidden = true;
      addError.hidden = true;
      addError.textContent = '';
    };
    closeEls.forEach((b) => b.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !dialog.hidden) close();
    });

    qtyDecr.addEventListener('click', () => {
      qtyInput.value = Math.max(1, (parseInt(qtyInput.value, 10) || 1) - 1);
    });
    qtyIncr.addEventListener('click', () => {
      qtyInput.value = (parseInt(qtyInput.value, 10) || 1) + 1;
    });

    const findVariant = (product, opts) => {
      return product.variants.find((v) => {
        const vo = v.options || [];
        return opts.every((o, i) => o == null || vo[i] === o);
      }) || null;
    };

    const renderOptions = (product) => {
      optionsEl.innerHTML = '';
      product.options.forEach((opt, i) => {
        const wrap = document.createElement('div');
        const head = document.createElement('p');
        head.className = 'boutique__product-option-name';
        head.textContent = opt.name;
        wrap.appendChild(head);
        const list = document.createElement('div');
        list.className = 'boutique__product-option-values';
        opt.values.forEach((value) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = value;
          btn.dataset.optionIndex = String(i);
          btn.dataset.value = value;
          const candidateOpts = state.selectedOptions.slice();
          candidateOpts[i] = value;
          const candidate = findVariant(product, candidateOpts);
          if (!candidate || !candidate.available) btn.classList.add('is-unavailable');
          if (state.selectedOptions[i] === value) btn.classList.add('is-selected');
          btn.addEventListener('click', () => {
            state.selectedOptions[i] = value;
            const v = findVariant(product, state.selectedOptions);
            if (v) {
              state.variant = v;
            } else {
              const fallback = product.variants.find((vv) => (vv.options || [])[i] === value);
              if (fallback) {
                state.variant = fallback;
                state.selectedOptions = (fallback.options || []).slice();
              }
            }
            renderOptions(product);
            renderVariant(product);
          });
          list.appendChild(btn);
        });
        wrap.appendChild(list);
        optionsEl.appendChild(wrap);
      });
    };

    const renderVariant = (product) => {
      const v = state.variant;
      if (!v) return;
      priceEl.textContent = v.price_formatted || '';
      if (v.compare_at_price && v.compare_at_price > v.price) {
        compareEl.textContent = v.compare_at_price_formatted || '';
        compareEl.hidden = false;
      } else {
        compareEl.hidden = true;
      }
      stockEl.classList.remove('is-low', 'is-out');
      if (!v.available) {
        stockEl.classList.add('is-out');
        stockEl.textContent = window.__boutiqueT('out_of_stock');
        addBtn.disabled = true;
        addLabel.textContent = window.__boutiqueT('sold_out');
      } else {
        const tracked = v.inventory_management && v.inventory_management.length > 0;
        const qty = (typeof v.inventory_quantity === 'number') ? v.inventory_quantity : null;
        if (tracked && qty != null && qty <= 5 && qty > 0) {
          stockEl.classList.add('is-low');
          stockEl.textContent = window.__boutiqueT('low_stock_n', { count: qty });
        } else if (tracked && qty != null && qty > 5) {
          stockEl.textContent = window.__boutiqueT('in_stock');
        } else {
          stockEl.textContent = window.__boutiqueT('in_stock');
        }
        addBtn.disabled = false;
        addLabel.textContent = window.__boutiqueT('add_to_cart');
      }
      const variantImage = v.featured_image || product.featured_image;
      renderMedia(product, variantImage);
    };

    const renderMedia = (product, primaryUrl) => {
      mediaEl.innerHTML = '';
      thumbsEl.innerHTML = '';
      const urls = uniq([primaryUrl, ...(product.images || [])].filter(Boolean));
      if (urls.length === 0) return;
      const main = document.createElement('img');
      main.alt = product.title;
      main.src = urls[0];
      main.loading = 'lazy';
      mediaEl.appendChild(main);
      urls.forEach((u, idx) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        if (idx === 0) btn.classList.add('is-active');
        const im = document.createElement('img');
        im.src = u;
        im.alt = '';
        btn.appendChild(im);
        btn.addEventListener('click', () => {
          main.src = u;
          thumbsEl.querySelectorAll('button').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
        });
        thumbsEl.appendChild(btn);
      });
    };

    addBtn.addEventListener('click', async () => {
      if (!state.variant) return;
      addError.hidden = true;
      addError.textContent = '';
      addBtn.disabled = true;
      addSpin.hidden = false;
      const qty = Math.max(1, parseInt(qtyInput.value, 10) || 1);
      try {
        await addToCart(root, state.variant.id, qty);
        addLabel.textContent = window.__boutiqueT('added');
        showToast(root, window.__boutiqueT('added_n', { title: state.product.title, count: qty }));
        setTimeout(() => {
          addLabel.textContent = window.__boutiqueT('add_to_cart');
          addBtn.disabled = false;
        }, 1200);
        await refreshCart(root);
        const cart = root.querySelector('[data-boutique-cart]');
        if (cart) cart.hidden = false;
      } catch (err) {
        addError.hidden = false;
        addError.textContent = err && err.message ? err.message : window.__boutiqueT('error_generic');
        addBtn.disabled = false;
      } finally {
        addSpin.hidden = true;
      }
    });

    window.__boutiqueOpenProduct = (product) => {
      if (!product || !Array.isArray(product.variants) || product.variants.length === 0) return;
      state.product = product;
      const firstAvailable = product.variants.find((v) => v.available) || product.variants[0];
      if (!firstAvailable) return;
      state.variant = firstAvailable;
      state.selectedOptions = (firstAvailable.options || []).slice();
      titleEl.textContent = product.title;
      vendorEl.textContent = product.vendor || '';
      descEl.innerHTML = '';
      if (product.description) {
        descEl.textContent = product.description;
      }
      if (linkEl) linkEl.href = product.url;
      qtyInput.value = '1';
      renderOptions(product);
      renderVariant(product);
      dialog.hidden = false;
      const focusable = dialog.querySelector('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
      if (focusable) focusable.focus({ preventScroll: true });
    };
  }

  function uniq(arr) {
    const seen = new Set();
    const out = [];
    arr.forEach((v) => {
      if (!seen.has(v)) { seen.add(v); out.push(v); }
    });
    return out;
  }

  function openProduct(product) {
    if (typeof window.__boutiqueOpenProduct === 'function') {
      window.__boutiqueOpenProduct(product);
    }
  }

  function ensureJs(url) {
    if (!url) return url;
    return /\.js(\?|$)/i.test(url) ? url : url.replace(/\/?$/, '') + '.js';
  }

  async function addToCart(root, variantId, quantity) {
    const url = ensureJs(root.dataset.cartAddUrl || '/cart/add.js');
    const res = await fetch(url, {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ items: [{ id: variantId, quantity }] }),
    });
    if (!res.ok) {
      let message = 'Cart error';
      try {
        const data = await res.json();
        message = data.description || data.message || message;
      } catch (_e) {}
      throw new Error(message);
    }
    return res.json();
  }

  function initCart(root) {
    const cart = root.querySelector('[data-boutique-cart]');
    const toggle = root.querySelector('[data-boutique-cart-toggle]');
    const closes = root.querySelectorAll('[data-boutique-cart-close]');
    if (!cart || !toggle) return;

    toggle.addEventListener('click', async () => {
      document.dispatchEvent(new Event('boutique-unlock-pointer'));
      cart.hidden = !cart.hidden;
      if (!cart.hidden) await refreshCart(root);
    });
    closes.forEach((b) => b.addEventListener('click', () => { cart.hidden = true; }));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !cart.hidden) cart.hidden = true;
    });

    refreshCart(root);
  }

  async function refreshCart(root) {
    const t = window.__boutiqueT;
    try {
      const cartUrl = ensureJs(root.dataset.cartUrl || '/cart');
      const res = await fetch(cartUrl, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' });
      if (!res.ok) return;
      const data = await res.json();
      const itemsEl = root.querySelector('[data-boutique-cart-items]');
      const emptyEl = root.querySelector('[data-boutique-cart-empty]');
      const subtotalEl = root.querySelector('[data-boutique-cart-subtotal]');
      const countEl = root.querySelector('[data-boutique-cart-count]');
      if (!itemsEl || !emptyEl || !subtotalEl || !countEl) return;
      const currencyCode =
        (typeof data.currency === 'string' && data.currency) ||
        data.currency_code ||
        root.dataset.shopCurrency ||
        'USD';
      countEl.textContent = String(data.item_count || 0);
      itemsEl.innerHTML = '';
      if (!data.items || data.items.length === 0) {
        emptyEl.hidden = false;
      } else {
        emptyEl.hidden = true;
        data.items.forEach((item) => {
          const li = document.createElement('li');
          li.dataset.line = String(item.key);
          const img = document.createElement('img');
          img.src = item.image || (item.featured_image && item.featured_image.url) || '';
          img.alt = item.product_title;
          const meta = document.createElement('div');
          meta.className = 'boutique__cart-meta';
          const title = document.createElement('span');
          title.className = 'boutique__cart-title';
          title.textContent = item.product_title;
          const variant = document.createElement('span');
          variant.className = 'boutique__cart-variant';
          variant.textContent = (item.variant_title && item.variant_title !== 'Default Title') ? item.variant_title : '';
          const price = document.createElement('span');
          price.className = 'boutique__cart-variant';
          const lineCents =
            item.final_line_price != null ? item.final_line_price : item.line_price;
          price.textContent = formatMoney(lineCents, currencyCode);
          meta.appendChild(title);
          if (variant.textContent) meta.appendChild(variant);
          meta.appendChild(price);
          const line = document.createElement('div');
          line.className = 'boutique__cart-line';
          const dec = document.createElement('button');
          dec.type = 'button';
          dec.textContent = '−';
          dec.setAttribute('aria-label', t('qty_minus'));
          const qty = document.createElement('span');
          qty.textContent = String(item.quantity);
          const inc = document.createElement('button');
          inc.type = 'button';
          inc.textContent = '+';
          inc.setAttribute('aria-label', t('qty_plus'));
          dec.addEventListener('click', () => changeLine(root, item.key, item.quantity - 1));
          inc.addEventListener('click', () => changeLine(root, item.key, item.quantity + 1));
          line.appendChild(dec);
          line.appendChild(qty);
          line.appendChild(inc);
          li.appendChild(img);
          li.appendChild(meta);
          li.appendChild(line);
          itemsEl.appendChild(li);
        });
      }
      subtotalEl.textContent = formatMoney(data.total_price, currencyCode);
    } catch (e) {
      console.warn('[boutique] cart fetch failed', e);
    }
  }

  async function changeLine(root, lineKey, quantity) {
    const baseUrl = ensureJs(root.dataset.cartChangeUrl || '/cart/change.js');
    try {
      const res = await fetch(baseUrl, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: lineKey, quantity: Math.max(0, quantity) }),
      });
      if (!res.ok) throw new Error('cart_change_failed');
    } catch (e) {
      console.warn('[boutique] line change failed', e);
    }
    await refreshCart(root);
  }

  function formatMoney(cents, currency) {
    const amount = (cents || 0) / 100;
    try {
      return new Intl.NumberFormat(undefined, { style: 'currency', currency: currency || 'USD' }).format(amount);
    } catch (_e) {
      return amount.toFixed(2) + ' ' + (currency || '');
    }
  }

  function showToast(root, message) {
    const toast = root.querySelector('[data-boutique-toast]');
    if (!toast) return;
    toast.textContent = message;
    toast.hidden = false;
    clearTimeout(toast._t);
    toast._t = setTimeout(() => { toast.hidden = true; }, 2400);
  }

  window.__boutiqueT = (key, vars) => {
    const dict = (window.__boutiqueDict = window.__boutiqueDict || {
      add_to_cart: {{ 'boutique.product.add' | t | json }},
      added: {{ 'boutique.product.added' | t | json }},
      added_n: {{ 'boutique.product.added_n' | t | json }},
      sold_out: {{ 'boutique.product.sold_out' | t | json }},
      out_of_stock: {{ 'boutique.product.out_of_stock' | t | json }},
      in_stock: {{ 'boutique.product.in_stock' | t | json }},
      low_stock_n: {{ 'boutique.product.low_stock_n' | t | json }},
      error_generic: {{ 'boutique.product.error_generic' | t | json }},
      qty_minus: {{ 'boutique.product.qty_minus' | t | json }},
      qty_plus: {{ 'boutique.product.qty_plus' | t | json }},
    });
    let s = dict[key] || key;
    if (vars) {
      Object.keys(vars).forEach((k) => {
        const esc = k.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        s = s.replace(new RegExp('\\[\\[' + esc + '\\]\\]', 'g'), String(vars[k]));
        s = s.replace(new RegExp('\\{\\{\\s*' + esc + '\\s*\\}\\}', 'g'), String(vars[k]));
      });
    }
    return s;
  };
</script>

