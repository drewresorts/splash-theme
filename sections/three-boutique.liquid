{%- liquid
  assign max_products = section.settings.max_products | default: 12
  assign boutique_use_collection_urls = false
  assign boutique_catalog_empty = false

  if section.settings.featured_collection != blank
    assign source_collection = collections[section.settings.featured_collection]
    if source_collection != blank
      assign products_source = source_collection.products
      assign boutique_use_collection_urls = true
    else
      assign products_source = collections.all.products
    endif
  else
    assign products_source = collections.all.products
  endif

  if products_source.size == 0
    assign boutique_catalog_empty = true
  endif

  assign floor_color = section.settings.floor_color | default: '#1a1a22'
  assign wall_color = section.settings.wall_color | default: '#0e0e14'
  assign ceiling_color = section.settings.ceiling_color | default: '#0b0b0f'
  assign accent_color = section.settings.accent_color | default: '#f5f5f5'
  assign room_radius = section.settings.room_radius | default: 9
  assign pedestal_height = section.settings.pedestal_height | default: 100
  assign quality = section.settings.quality | default: 'auto'
  assign enable_shadows = section.settings.enable_shadows
  assign three_version = '0.165.0'
-%}

{%- capture products_json -%}
[
{%- for product in products_source limit: max_products -%}
{%- unless forloop.first %},{% endunless -%}
{
"id":{{ product.id | json }},
"handle":{{ product.handle | json }},
"title":{{ product.title | json }},
"vendor":{{ product.vendor | json }},
"type":{{ product.type | json }},
"url":{%- if boutique_use_collection_urls -%}{{ product.url | within: source_collection | json }}{%- else -%}{{ product.url | json }}{%- endif -%},
"available":{{ product.available }},
"description":{{ product.description | strip_html | strip_newlines | truncate: 600 | json }},
"price_min":{{ product.price_min | json }},
"price_max":{{ product.price_max | json }},
"price_min_formatted":{{ product.price_min | money | json }},
"price_max_formatted":{{ product.price_max | money | json }},
"compare_at_price_min":{{ product.compare_at_price_min | json }},
"compare_at_price_min_formatted":{%- if product.compare_at_price_min and product.compare_at_price_min > 0 -%}{{ product.compare_at_price_min | money | json }}{%- else -%}null{%- endif -%},
"price_varies":{{ product.price_varies }},
"featured_image":{%- if product.featured_image -%}{{ product.featured_image | image_url: width: 1200 | json }}{%- else -%}null{%- endif -%},
"options":[
{%- for opt in product.options_with_values -%}
{%- unless forloop.first %},{% endunless -%}
{"name":{{ opt.name | json }},"position":{{ opt.position | json }},"values":[
{%- for v in opt.values -%}
{%- unless forloop.first %},{% endunless -%}
{{ v | json }}
{%- endfor -%}
]}
{%- endfor -%}
],
"variants":[
{%- for v in product.variants -%}
{%- unless forloop.first %},{% endunless -%}
{
"id":{{ v.id | json }},
"title":{{ v.title | json }},
"available":{{ v.available }},
"price":{{ v.price | json }},
"price_formatted":{{ v.price | money | json }},
"compare_at_price":{{ v.compare_at_price | json }},
"compare_at_price_formatted":{%- if v.compare_at_price and v.compare_at_price > 0 -%}{{ v.compare_at_price | money | json }}{%- else -%}null{%- endif -%},
"options":{{ v.options | json }},
"sku":{{ v.sku | json }},
"requires_selling_plan":{{ v.requires_selling_plan }},
"inventory_management":{{ v.inventory_management | json }},
"inventory_policy":{{ v.inventory_policy | json }},
"inventory_quantity":{{ v.inventory_quantity | json }},
"featured_image":{%- if v.featured_image -%}{{ v.featured_image.src | image_url: width: 1200 | json }}{%- else -%}null{%- endif -%}
}
{%- endfor -%}
],
"images":[
{%- for image in product.images limit: 8 -%}
{%- unless forloop.first %},{% endunless -%}
{{ image | image_url: width: 1400 | json }}
{%- endfor -%}
],
"media":[
{%- for m in product.media -%}
{%- unless forloop.first %},{% endunless -%}
{
"id":{{ m.id | json }},
"media_type":{{ m.media_type | json }},
"alt":{{ m.alt | json }},
"position":{{ m.position | json }},
"preview_url":{%- if m.preview_image -%}{{ m.preview_image | image_url: width: 1400 | json }}{%- else -%}null{%- endif -%},
"sources":[
{%- if m.media_type == 'model' -%}
{%- for s in m.sources -%}
{%- unless forloop.first %},{% endunless -%}
{"url":{{ s.url | json }},"format":{{ s.format | json }},"mime_type":{{ s.mime_type | json }}}
{%- endfor -%}
{%- endif -%}
]
}
{%- endfor -%}
]
}
{%- endfor -%}
]
{%- endcapture -%}

{%- capture boutique_settings -%}
{
"floorColor":{{ floor_color | json }},
"wallColor":{{ wall_color | json }},
"ceilingColor":{{ ceiling_color | json }},
"accentColor":{{ accent_color | json }},
"roomRadius":{{ room_radius | json }},
"pedestalHeight":{{ pedestal_height | divided_by: 100.0 | json }},
"quality":{{ quality | json }},
"enableShadows":{{ enable_shadows | json }},
"floorTexture":{%- if section.settings.floor_texture -%}{{ section.settings.floor_texture | image_url: width: 1024 | json }}{%- else -%}null{%- endif -%},
"wallTexture":{%- if section.settings.wall_texture -%}{{ section.settings.wall_texture | image_url: width: 1024 | json }}{%- else -%}null{%- endif -%},
"skyboxImage":{%- if section.settings.skybox_image -%}{{ section.settings.skybox_image | image_url: width: 2048 | json }}{%- else -%}null{%- endif -%},
"threeVersion":{{ three_version | json }}
}
{%- endcapture -%}

<div
  class="boutique"
  data-boutique
  data-three-version="{{ three_version }}"
  data-cart-add-url="{{ routes.cart_add_url }}"
  data-cart-change-url="{{ routes.cart_change_url }}"
  data-cart-url="{{ routes.cart_url }}"
  data-shop-currency="{{ shop.currency }}"
>
  <noscript>
    <div class="boutique__noscript">
      <h1>{{ 'boutique.noscript.heading' | t }}</h1>
      <p>{{ 'boutique.noscript.body' | t }}</p>
      <ul class="boutique__noscript-list">
        {%- for product in products_source limit: max_products -%}
          <li>
            <a href="{% if boutique_use_collection_urls %}{{ product.url | within: source_collection }}{% else %}{{ product.url }}{% endif %}">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
              {%- endif -%}
              <strong>{{ product.title | escape }}</strong>
              <span>{{ product.price_min | money }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </noscript>

  <div class="boutique__intro" data-boutique-intro hidden>
    <div class="boutique__intro-inner">
      {%- if section.settings.eyebrow != blank -%}
        <p class="boutique__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="boutique__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="boutique__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if boutique_catalog_empty -%}
        <p class="boutique__empty-catalog">{{ 'boutique.intro.empty_catalog' | t }}</p>
      {%- endif -%}
      <button
        type="button"
        class="boutique__enter"
        data-boutique-enter
        {% if boutique_catalog_empty %}
          hidden
          disabled
          aria-disabled="true"
        {% endif %}
      >
        {{ section.settings.cta_label | default: 'Enter the boutique' | escape }}
      </button>
      <div class="boutique__legend" aria-hidden="true">
        <span><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> {{ 'boutique.legend.move' | t }}</span>
        <span><kbd>{{ 'boutique.legend.mouse' | t }}</kbd> {{ 'boutique.legend.look' | t }}</span>
        <span><kbd>E</kbd> / <kbd>{{ 'boutique.legend.click' | t }}</kbd> {{ 'boutique.legend.interact' | t }}</span>
        <span><kbd>Esc</kbd> {{ 'boutique.legend.exit' | t }}</span>
      </div>
      <button type="button" class="boutique__skip" data-boutique-skip-3d>
        {{ 'boutique.intro.skip_3d' | t }}
      </button>
    </div>
  </div>

  <div class="boutique__loading" data-boutique-loading aria-live="polite">
    <div class="boutique__loading-bar"><span data-boutique-loading-bar></span></div>
    <p class="boutique__loading-text" data-boutique-loading-text>{{ 'boutique.loading' | t }}</p>
  </div>

  <div class="boutique__stage" data-boutique-stage aria-hidden="true"></div>

  <div class="boutique__hud" data-boutique-hud hidden>
    <button type="button" class="boutique__hud-btn boutique__hud-back" data-boutique-back aria-label="{{ 'boutique.hud.back' | t }}">
      &#x2715;
    </button>
    <button type="button" class="boutique__hud-btn boutique__hud-cart" data-boutique-cart-toggle aria-label="{{ 'boutique.hud.cart' | t }}">
      <span class="boutique__hud-cart-icon" aria-hidden="true">&#x1F6CD;</span>
      <span class="boutique__hud-cart-count" data-boutique-cart-count>0</span>
    </button>
    <div class="boutique__crosshair" data-boutique-crosshair aria-hidden="true">
      <div class="boutique__crosshair-dot"></div>
      <div class="boutique__crosshair-ring" data-boutique-crosshair-ring></div>
      <div class="boutique__crosshair-hint" data-boutique-crosshair-hint hidden>
        <span data-boutique-crosshair-text>{{ 'boutique.crosshair.inspect' | t }}</span>
      </div>
    </div>
  </div>

  <div class="boutique__joystick" data-boutique-joystick hidden aria-hidden="true">
    <div class="boutique__joystick-base">
      <div class="boutique__joystick-stick" data-boutique-joystick-stick></div>
    </div>
  </div>

  <div class="boutique__product" data-boutique-product role="dialog" aria-modal="true" aria-labelledby="BoutiqueProductTitle" hidden>
    <div class="boutique__product-backdrop" data-boutique-product-close></div>
    <div class="boutique__product-panel">
      <button type="button" class="boutique__product-close" data-boutique-product-close aria-label="{{ 'boutique.product.close' | t }}">&#x2715;</button>
      <div class="boutique__product-gallery">
        <div class="boutique__product-media" data-boutique-product-media></div>
        <div class="boutique__product-thumbs" data-boutique-product-thumbs></div>
      </div>
      <div class="boutique__product-info">
        <p class="boutique__product-vendor" data-boutique-product-vendor></p>
        <h2 class="boutique__product-title" id="BoutiqueProductTitle" data-boutique-product-title></h2>
        <p class="boutique__product-price">
          <span data-boutique-product-price></span>
          <span class="boutique__product-compare" data-boutique-product-compare hidden></span>
        </p>
        <p class="boutique__product-stock" data-boutique-product-stock></p>
        <div class="boutique__product-options" data-boutique-product-options></div>
        <div class="boutique__product-quantity">
          <label for="BoutiqueProductQty">{{ 'boutique.product.quantity' | t }}</label>
          <div class="boutique__qty">
            <button type="button" data-boutique-qty-decr aria-label="{{ 'boutique.product.qty_minus' | t }}">&minus;</button>
            <input id="BoutiqueProductQty" type="number" min="1" step="1" value="1" data-boutique-qty>
            <button type="button" data-boutique-qty-incr aria-label="{{ 'boutique.product.qty_plus' | t }}">+</button>
          </div>
        </div>
        <button type="button" class="boutique__product-add" data-boutique-add>
          <span data-boutique-add-label>{{ 'boutique.product.add' | t }}</span>
          <span class="boutique__product-add-spin" data-boutique-add-spin hidden></span>
        </button>
        <p class="boutique__product-error" data-boutique-add-error hidden role="alert"></p>
        <div class="boutique__product-description" data-boutique-product-description></div>
        <a class="boutique__product-link" data-boutique-product-link>{{ 'boutique.product.view_full' | t }} &rarr;</a>
      </div>
    </div>
  </div>

  <aside class="boutique__cart" data-boutique-cart role="dialog" aria-modal="true" aria-labelledby="BoutiqueCartTitle" hidden>
    <div class="boutique__cart-backdrop" data-boutique-cart-close></div>
    <div class="boutique__cart-panel">
      <header class="boutique__cart-header">
        <h2 id="BoutiqueCartTitle">{{ 'boutique.cart.title' | t }}</h2>
        <button type="button" data-boutique-cart-close aria-label="{{ 'boutique.cart.close' | t }}">&#x2715;</button>
      </header>
      <ul class="boutique__cart-items" data-boutique-cart-items></ul>
      <p class="boutique__cart-empty" data-boutique-cart-empty>{{ 'boutique.cart.empty' | t }}</p>
      <footer class="boutique__cart-footer">
        <div class="boutique__cart-subtotal">
          <span>{{ 'boutique.cart.subtotal' | t }}</span>
          <strong data-boutique-cart-subtotal></strong>
        </div>
        <a class="boutique__cart-checkout" href="{{ routes.cart_url }}" data-boutique-checkout>
          {{ 'boutique.cart.checkout' | t }}
        </a>
      </footer>
    </div>
  </aside>

  <div class="boutique__fallback" data-boutique-fallback hidden>
    <div class="boutique__fallback-inner">
      <p class="boutique__fallback-note">{{ 'boutique.fallback.note' | t }}</p>
      <ul class="boutique__fallback-grid">
        {%- for product in products_source limit: max_products -%}
          <li class="boutique__fallback-card">
            <a href="{% if boutique_use_collection_urls %}{{ product.url | within: source_collection }}{% else %}{{ product.url }}{% endif %}">
              {%- if product.featured_image -%}
                {{
                  product.featured_image
                  | image_url: width: 800
                  | image_tag: loading: 'lazy', alt: product.title, class: 'boutique__fallback-img'
                }}
              {%- endif -%}
              <span class="boutique__fallback-title">{{ product.title | escape }}</span>
              <span class="boutique__fallback-price">
                {%- if product.price_varies -%}
                  {%- assign fallback_from_price = product.price_min | money -%}
                  {{ 'boutique.fallback.from_price_html' | t: price: fallback_from_price }}
                {%- else -%}
                  {{ product.price_min | money }}
                {%- endif -%}
              </span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

  <div class="boutique__toast" data-boutique-toast hidden role="status" aria-live="polite"></div>

  <script type="application/json" data-boutique-products>{{ products_json | replace: '</', '<\/' }}</script>
  <script type="application/json" data-boutique-config>{{ boutique_settings | replace: '</', '<\/' }}</script>
</div>

{% stylesheet %}
  .boutique {
    position: relative;
    display: block;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 30%, rgba(255, 255, 255, 0.05), transparent 70%),
      var(--boutique-bg, #0b0b0f);
    color: var(--boutique-fg, #f5f5f5);
    isolation: isolate;
    font-family: var(--font-body-family, system-ui, sans-serif);
  }

  .boutique__stage {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .boutique__stage canvas {
    display: block;
    width: 100%;
    height: 100%;
    cursor: grab;
  }

  .boutique__stage.is-locked canvas {
    cursor: none;
  }

  .boutique__intro,
  .boutique__loading,
  .boutique__hud,
  .boutique__product,
  .boutique__cart,
  .boutique__fallback,
  .boutique__joystick,
  .boutique__toast {
    position: absolute;
    z-index: 5;
  }

  .boutique__intro {
    inset: 0;
    display: grid;
    place-items: center;
    padding: 2rem;
    background: radial-gradient(circle at 50% 40%, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.85));
    backdrop-filter: blur(6px);
    text-align: center;
  }

  .boutique__intro[hidden] {
    display: none;
  }

  .boutique__intro-inner {
    width: min(640px, 92vw);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .boutique__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: 0.78rem;
    opacity: 0.85;
  }

  .boutique__heading {
    margin: 0;
    font-size: clamp(2.25rem, 6vw, 4.25rem);
    line-height: 1.05;
    font-weight: 600;
  }

  .boutique__subheading {
    margin: 0;
    max-width: 52ch;
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    line-height: 1.5;
    opacity: 0.85;
  }

  .boutique__enter {
    margin-top: 0.5rem;
    padding: 0.95rem 1.6rem;
    border-radius: 999px;
    border: 1px solid currentColor;
    background: var(--boutique-fg, #f5f5f5);
    color: #0b0b0f;
    font: inherit;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: transform 120ms ease, opacity 120ms ease;
  }

  .boutique__enter:hover,
  .boutique__enter:focus-visible {
    transform: translateY(-1px);
    outline: none;
  }

  .boutique__enter[disabled] {
    opacity: 0.65;
    cursor: progress;
    transform: none;
  }

  .boutique__legend {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
    font-size: 0.78rem;
    opacity: 0.75;
  }

  .boutique__legend kbd {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    border: 1px solid color-mix(in srgb, currentColor 50%, transparent);
    border-radius: 0.35rem;
    font-family: ui-monospace, monospace;
    font-size: 0.72rem;
    margin-right: 0.15rem;
  }

  .boutique__empty-catalog {
    margin: 0;
    max-width: 48ch;
    font-size: 0.95rem;
    line-height: 1.45;
    color: #ffb4b4;
  }

  .boutique__skip {
    margin-top: 0.25rem;
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    font-size: 0.85rem;
    text-decoration: underline;
    text-underline-offset: 4px;
    opacity: 0.75;
    cursor: pointer;
  }

  .boutique__loading {
    inset: auto 0 0 0;
    bottom: 1.5rem;
    margin: 0 auto;
    width: min(420px, 88vw);
    text-align: center;
    z-index: 6;
  }

  .boutique__loading[hidden] {
    display: none;
  }

  .boutique__loading-bar {
    position: relative;
    height: 3px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    overflow: hidden;
  }

  .boutique__loading-bar span {
    display: block;
    height: 100%;
    width: 0%;
    background: currentColor;
    transition: width 200ms ease;
  }

  .boutique__loading-text {
    margin: 0.5rem 0 0;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .boutique__hud {
    inset: 0;
    pointer-events: none;
  }

  .boutique__hud[hidden] {
    display: none;
  }

  .boutique__hud-btn {
    position: absolute;
    pointer-events: auto;
    background: rgba(15, 15, 20, 0.65);
    color: var(--boutique-fg, #f5f5f5);
    border: 1px solid color-mix(in srgb, currentColor 35%, transparent);
    border-radius: 999px;
    padding: 0.55rem 0.85rem;
    font: inherit;
    font-size: 1rem;
    cursor: pointer;
    backdrop-filter: blur(6px);
    transition: transform 120ms ease, background 120ms ease;
  }

  .boutique__hud-btn:hover,
  .boutique__hud-btn:focus-visible {
    transform: translateY(-1px);
    background: rgba(15, 15, 20, 0.85);
    outline: none;
  }

  .boutique__hud-back {
    top: 1rem;
    left: 1rem;
  }

  .boutique__hud-cart {
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .boutique__hud-cart-count {
    min-width: 1.2rem;
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    background: var(--boutique-accent, #f5f5f5);
    color: #0b0b0f;
    font-size: 0.78rem;
    font-weight: 600;
    text-align: center;
  }

  .boutique__crosshair {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60px;
    height: 60px;
    transform: translate(-50%, -50%);
    pointer-events: none;
    display: grid;
    place-items: center;
  }

  .boutique__crosshair-dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.45);
  }

  .boutique__crosshair-ring {
    position: absolute;
    inset: 50% 50%;
    width: 26px;
    height: 26px;
    border: 1px solid color-mix(in srgb, currentColor 60%, transparent);
    border-radius: 999px;
    transform: translate(-50%, -50%) scale(0.6);
    transition: transform 160ms ease, border-color 160ms ease, opacity 160ms ease;
    opacity: 0;
  }

  .boutique__crosshair-ring.is-active {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    border-color: var(--boutique-accent, #f5f5f5);
  }

  .boutique__crosshair-hint {
    position: absolute;
    top: 110%;
    left: 50%;
    transform: translateX(-50%);
    max-width: min(60vw, 320px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    background: rgba(0, 0, 0, 0.65);
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
  }

  .boutique__crosshair-hint[hidden] {
    display: none;
  }

  .boutique__joystick {
    bottom: 1.5rem;
    left: 1.5rem;
    width: 120px;
    height: 120px;
    z-index: 6;
    pointer-events: auto;
    touch-action: none;
  }

