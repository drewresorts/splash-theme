{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign orders_per_page = section.settings.orders_per_page | default: 20
  if orders_per_page < 5
    assign orders_per_page = 5
  elsif orders_per_page > 50
    assign orders_per_page = 50
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer account customer--account-dashboard section-{{ section.id }}-padding">
  <header class="customer__account-header">
    <div class="customer__account-header-text">
      <h1 class="customer__title">{{ 'customer.account.title' | t }}</h1>
      {%- if section.settings.show_profile_email and customer.email != blank -%}
        <p class="customer__account-email">
          <span class="visually-hidden">{{ 'customer.account.signed_in_as' | t }}</span>
          {{ customer.email | escape }}
        </p>
      {%- endif -%}
    </div>
    <div class="customer__account-header-actions">
      {%- if section.settings.show_continue_shopping -%}
        <a class="button button--secondary" href="{{ routes.root_url }}">
          {{ 'customer.account.continue_shopping' | t }}
        </a>
      {%- endif -%}
      <a class="customer__account-logout" href="{{ routes.account_logout_url }}">
        <span class="svg-wrapper">
          {{- 'icon-account.svg' | inline_asset_content -}}
        </span>
        {{ 'customer.log_out' | t }}
      </a>
    </div>
  </header>

  <nav class="customer__account-nav" aria-label="{{ 'customer.account.nav_aria' | t }}">
    <a class="customer__account-nav-link customer__account-nav-link--current" href="{{ routes.account_url }}">
      {{ 'customer.account.nav_overview' | t }}
    </a>
    <a class="customer__account-nav-link" href="{{ routes.account_url }}#order-history">
      {{ 'customer.orders.title' | t }}
    </a>
    <a class="customer__account-nav-link" href="{{ routes.account_addresses_url }}">
      {{ 'customer.account.view_addresses' | t -}}
      <span class="customer__account-nav-count">({{ customer.addresses_count }})</span>
    </a>
    {%- if section.settings.help_link != blank -%}
      <a class="customer__account-nav-link" href="{{ section.settings.help_link }}">
        {{ 'customer.account.help' | t }}
      </a>
    {%- endif -%}
    {%- if section.settings.returns_link != blank -%}
      <a class="customer__account-nav-link" href="{{ section.settings.returns_link }}">
        {{ 'customer.account.returns' | t }}
      </a>
    {%- endif -%}
  </nav>

  <div class="customer__account-grid">
    <div id="order-history" class="customer__account-orders" tabindex="-1">
      <h2>{{ 'customer.orders.title' | t }}</h2>

      {% paginate customer.orders by orders_per_page %}
        {%- if customer.orders.size > 0 -%}
          <table role="table" class="order-history">
            <caption class="visually-hidden">
              {{ 'customer.orders.title' | t }}
            </caption>
            <thead role="rowgroup">
              <tr role="row">
                <th id="ColumnOrder" scope="col" role="columnheader">{{ 'customer.orders.order_number' | t }}</th>
                <th id="ColumnDate" scope="col" role="columnheader">{{ 'customer.orders.date' | t }}</th>
                <th id="ColumnPayment" scope="col" role="columnheader">{{ 'customer.orders.payment_status' | t }}</th>
                <th id="ColumnFulfillment" scope="col" role="columnheader">
                  {{ 'customer.orders.fulfillment_status' | t }}
                </th>
                <th id="ColumnTotal" scope="col" role="columnheader">{{ 'customer.orders.total' | t }}</th>
              </tr>
            </thead>
            <tbody role="rowgroup">
              {%- for order in customer.orders -%}
                {%- assign row_id = 'RowOrder-' | append: forloop.index -%}
                <tr role="row">
                  <td
                    id="{{ row_id }}"
                    role="cell"
                    headers="ColumnOrder"
                    data-label="{{ 'customer.orders.order_number' | t }}"
                  >
                    <a
                      href="{{ order.customer_url }}"
                      aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
                    >
                      {{ order.name }}
                    </a>
                  </td>
                  <td headers="{{ row_id }} ColumnDate" role="cell" data-label="{{ 'customer.orders.date' | t }}">
                    {{ order.created_at | time_tag: format: 'date' }}
                  </td>
                  <td
                    headers="{{ row_id }} ColumnPayment"
                    role="cell"
                    data-label="{{ 'customer.orders.payment_status' | t }}"
                  >
                    {{ order.financial_status_label }}
                  </td>
                  <td
                    headers="{{ row_id }} ColumnFulfillment"
                    role="cell"
                    data-label="{{ 'customer.orders.fulfillment_status' | t }}"
                  >
                    {{ order.fulfillment_status_label }}
                  </td>
                  <td headers="{{ row_id }} ColumnTotal" role="cell" data-label="{{ 'customer.orders.total' | t }}">
                    {{ order.total_net_amount | money_with_currency }}
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        {%- else -%}
          <p>{{ 'customer.orders.none' | t }}</p>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          {%- if paginate.parts.size > 0 -%}
            <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
              <ul role="list">
                {%- if paginate.previous -%}
                  <li>
                    <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  <li>
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                        {{- part.title -}}
                      </a>
                    {%- else -%}
                      {%- if part.title == paginate.current_page -%}
                        <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                          {{- part.title -}}
                        </span>
                      {%- else -%}
                        <span>{{ part.title }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  </li>
                {%- endfor -%}

                {%- if paginate.next -%}
                  <li>
                    <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            </nav>
          {%- endif -%}
        {%- endif -%}
      {% endpaginate %}
    </div>

    <aside class="customer__account-sidebar">
      <h2>{{ 'customer.account.details' | t }}</h2>

      {%- if customer.default_address -%}
        <div class="customer__account-address rte">
          {{ customer.default_address | format_address }}
        </div>
      {%- else -%}
        <p>{{ 'customer.account.no_default_address' | t }}</p>
      {%- endif -%}

      <a class="button" href="{{ routes.account_addresses_url }}">
        {{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
      </a>
    </aside>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-account.settings.header_account.content"
    },
    {
      "type": "range",
      "id": "orders_per_page",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 20,
      "label": "t:sections.main-account.settings.orders_per_page.label",
      "info": "t:sections.main-account.settings.orders_per_page.info"
    },
    {
      "type": "checkbox",
      "id": "show_profile_email",
      "default": true,
      "label": "t:sections.main-account.settings.show_profile_email.label"
    },
    {
      "type": "checkbox",
      "id": "show_continue_shopping",
      "default": true,
      "label": "t:sections.main-account.settings.show_continue_shopping.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-account.settings.header_links.content"
    },
    {
      "type": "url",
      "id": "help_link",
      "label": "t:sections.main-account.settings.help_link.label",
      "info": "t:sections.main-account.settings.help_link.info"
    },
    {
      "type": "url",
      "id": "returns_link",
      "label": "t:sections.main-account.settings.returns_link.label",
      "info": "t:sections.main-account.settings.returns_link.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
