{% comment %}
  Video color overlay for splash-streams (video_overlay block).
  Uses the same overlay technique as the coming-soon section.

  Accepts:
  - block: {Object} video_overlay block
{% endcomment %}

{%- liquid
  assign overlay_opacity = block.settings.overlay_opacity | default: 55
  assign overlay_color = block.settings.overlay_color | default: '#0b0b0f'
  assign overlay_placement = block.settings.placement | default: 'full_screen'
-%}

<div
  id="SplashVideoOverlay-{{ block.id }}"
  class="splash-streams__video-overlay splash-streams__video-overlay--{{ overlay_placement }}"
  style="
    --overlay-color: {{ overlay_color }};
    --overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};
  "
  aria-hidden="true"
  {{ block.shopify_attributes }}
></div>
