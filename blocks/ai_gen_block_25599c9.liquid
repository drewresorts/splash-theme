{% doc %}
  @prompt
    A custom Video background section with a custom image button directly in the center of the block
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-bg-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: {{ block.settings.section_height }}px;
    overflow: hidden;
  }

  .ai-video-bg__video-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-video-bg__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-bg__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-video-bg__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .ai-video-bg__button-{{ ai_gen_id }} {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    overflow: hidden;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }

  .ai-video-bg__button-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  .ai-video-bg__button-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-bg__button-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-video-bg__button-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-video-bg__button-icon-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
    pointer-events: none;
  }

  .ai-video-bg__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-align: center;
    max-width: 600px;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  @media screen and (max-width: 749px) {
    .ai-video-bg-{{ ai_gen_id }} {
      height: {{ block.settings.section_height | times: 0.7 }}px;
    }

    .ai-video-bg__button-{{ ai_gen_id }} {
      width: {{ block.settings.button_size | times: 0.8 }}px;
      height: {{ block.settings.button_size | times: 0.8 }}px;
    }

    .ai-video-bg__button-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-video-bg__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.8 }}px;
      max-width: 90%;
    }
  }
{% endstyle %}

<video-background-{{ ai_gen_id }}
  class="ai-video-bg-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-bg__video-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      <video
        class="ai-video-bg__video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
      >
        <source src="{{ block.settings.video_url }}" type="video/mp4">
      </video>
    {% endif %}
  </div>

  <div class="ai-video-bg__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-video-bg__content-{{ ai_gen_id }}">
    {% if block.settings.button_link != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-video-bg__button-{{ ai_gen_id }}"
        aria-label="{{ block.settings.button_aria_label }}"
      >
        {% if block.settings.button_image %}
          <img
            src="{{ block.settings.button_image | image_url: width: 400 }}"
            alt="{{ block.settings.button_image.alt | escape }}"
            class="ai-video-bg__button-image-{{ ai_gen_id }}"
            loading="lazy"
            width="400"
            height="400"
          >
        {% else %}
          <div class="ai-video-bg__button-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.show_icon %}
          <svg
            class="ai-video-bg__button-icon-{{ ai_gen_id }}"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M8 5v14l11-7z"/>
          </svg>
        {% endif %}
      </a>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-video-bg__text-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% endif %}
  </div>
</video-background-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoBackground{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-video-bg__video-{{ ai_gen_id }}');
        if (this.video) {
          this.ensureVideoPlays();
        }
      }

      ensureVideoPlays() {
        const playPromise = this.video.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {
            this.video.muted = true;
            this.video.play();
          });
        }
      }
    }

    customElements.define('video-background-{{ ai_gen_id }}', VideoBackground{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video background",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 300,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "image_picker",
      "id": "button_image",
      "label": "Button image"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_aria_label",
      "label": "Button accessibility label",
      "default": "Play video"
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button size",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show play icon",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Video background"
    }
  ]
}
{% endschema %}
